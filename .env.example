# Vultr API key (https://my.vultr.com/settings/#settingsapi)
VULTR_API_KEY=

# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp

# Speechmatics API key for Atlas voice commands (server-side only)
SPEECHMATICS_API_KEY=
SPEECHMATICS_LANGUAGE=en

# Required for signed Atlas sessions. Use a long random value in production.
ATLAS_SESSION_SECRET=

# Owner mandate for the live demo: username admin, password demo.
ATLAS_ADMIN_PASSWORD=demo
ATLAS_DEMO_PASSWORD=demo
